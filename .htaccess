# Configuración de Hostinger para ERPod
DirectoryIndex frontend/modules/core/landing.html

# Redirigir la raíz a la landing page si DirectoryIndex no es suficiente
RewriteEngine On
RewriteRule ^$ frontend/modules/core/landing.html [L]

# Asegurar que las rutas de los módulos funcionen si se accede directamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ frontend/$1 [L]
