# ============================================================
# EDATIA ERP - Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA commits el archivo .env al repositorio
# ============================================================

# DATABASE (PostgreSQL)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB?schema=public
DATABASE_URL="postgresql://CAMBIAR_USUARIO:CAMBIAR_CONTRASEÑA@db:5432/edatia_erp?schema=public"

# AUTH - JWT
# Genera un secret seguro con: openssl rand -base64 64
JWT_SECRET="CAMBIAR_POR_SECRET_ALEATORIO_MINIMO_64_CHARS"
JWT_EXPIRES_IN="1d"

# SERVER
PORT=4000
NODE_ENV=production

# DB CREDENTIALS (usadas en docker-compose)
DB_USER="CAMBIAR_USUARIO_DB"
DB_PASSWORD="CAMBIAR_CONTRASEÑA_DB"
DB_NAME="edatia_erp"
