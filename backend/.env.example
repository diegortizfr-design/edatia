# ══════════════════════════════════════════════════════════════════════════════
# Edatia ERP — Variables de entorno
# Copia este archivo como `.env` y completa los valores reales.
# NUNCA subas `.env` al repositorio — está en .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://admin:CAMBIA_ESTA_PASSWORD@db:5432/edatia_erp?schema=public"

# ── Auth ERP (usuarios del SaaS) ──────────────────────────────────────────────
# Genera un secret aleatorio de al menos 64 caracteres:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="GENERA_UN_SECRET_ALEATORIO_MINIMO_64_CHARS"
JWT_EXPIRES_IN="1d"

# ── Auth Manager (portal interno Edatia) ─────────────────────────────────────
# Usa un secret DIFERENTE al de JWT_SECRET.
# Genera otro con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
MANAGER_JWT_SECRET="GENERA_OTRO_SECRET_DIFERENTE_MINIMO_64_CHARS"
MANAGER_JWT_EXPIRES_IN="8h"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
# En producción: production | En desarrollo: development
NODE_ENV=production

# ── Credenciales de BD (usadas por docker-compose) ───────────────────────────
# Deben coincidir con los valores de DATABASE_URL
DB_USER=admin
DB_PASSWORD=CAMBIA_ESTA_PASSWORD
DB_NAME=edatia_erp

# ══════════════════════════════════════════════════════════════════════════════
# CHECKLIST DE SEGURIDAD ANTES DE DEPLOY A PRODUCCIÓN:
#
# [ ] JWT_SECRET tiene al menos 48 bytes aleatorios (96 caracteres hex)
# [ ] MANAGER_JWT_SECRET es DIFERENTE a JWT_SECRET
# [ ] DB_PASSWORD no es la contraseña por defecto
# [ ] NODE_ENV=production  →  deshabilita Swagger, restringe CORS
# [ ] Verificar que .env NO está en git:  git status .env
# ══════════════════════════════════════════════════════════════════════════════
