// backend/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nombre    String?
  usuario   String   @unique
  password  String
  rol       String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  empresaId Int?
  empresa   Empresa? @relation(fields: [empresaId], references: [id])
}

model Profile {
  id     Int     @id @default(autoincrement())
  bio    String?
  userId Int     @unique
  user   User    @relation(fields: [userId], references: [id])
}

model Empresa {
  id        Int      @id @default(autoincrement())
  nit       String   @unique
  nombre    String
  direccion String?
  telefono  String?
  email     String?
  // Datos DIAN
  municipio            String?
  departamento         String?
  codigoDane           String?   // código DANE municipio (ej: 11001 = Bogotá)
  codigoPostal         String?
  regimenFiscal        String?   @default("48")  // 48=Responsable IVA, 49=No responsable
  actividadEconomica   String?   // CIIU
  responsabilidades    String[]  // códigos responsabilidad tributaria DIAN
  tipoPersona          String?   @default("JURIDICA")
  digitoVerificacion   String?
  logo                 String?
  permiteStockNegativo Boolean @default(false)
  usuarios  User[]
  createdAt DateTime @default(now())

  // ── Inventario ────────────────────────────────────
  categorias           Categoria[]
  marcas               Marca[]
  unidadesMedida       UnidadMedida[]
  productos            Producto[]
  bodegas              Bodega[]
  stock                Stock[]
  movimientosInventario MovimientoInventario[]
  proveedores          Proveedor[]
  ordenesCompra        OrdenCompra[]
  recepcionesMercancia RecepcionMercancia[]
  lotes                Lote[]
  seriales             NumeroSerie[]
  variantes            VarianteProducto[]

  // ── Ventas ────────────────────────────────────────
  clientes             ClienteERP[]
  cotizaciones         Cotizacion[]
  facturasVenta        FacturaVenta[]
  notasCredito         NotaCredito[]
  recibosCaja          ReciboCaja[]
  configDIAN           ConfiguracionDIAN?

  // ── Contabilidad ──────────────────────────────────
  cuentasPUC           CuentaPUC[]
  periodos             PeriodoContable[]
  comprobantes         Comprobante[]

  // ── POS ───────────────────────────────────────────
  cajasPos             CajaPos[]
  sesionesPos          SesionCaja[]
  ventasPos            VentaPos[]
}

// ─── Edatia Manager ───────────────────────────────────────────────────────────

model PerfilCargo {
  id                Int           @id @default(autoincrement())
  nombre            String        @unique
  descripcion       String?
  responsabilidades String?       // Texto libre con responsabilidades del cargo
  correoPrincipal   String?       // ej. comercial@edatia.com
  subcorreos        String[]      // ej. [comercial1@edatia.com, comercial2@edatia.com]
  permisos          String[]
  documentoUrl      String?       // URL o path al manual de funciones / PDF del área
  colaboradores     Colaborador[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Colaborador {
  id            Int          @id @default(autoincrement())

  // ── Acceso al sistema ──────────────────────────────
  email         String       @unique  // correo corporativo = login
  password      String
  rol           String       // ADMIN | COMERCIAL | COORDINACION | OPERACION
  activo        Boolean      @default(true)

  // ── Datos personales ───────────────────────────────
  nombre            String
  tipoDocumento     String?   // CC / CE / Pasaporte / NIT
  numeroDocumento   String?
  fechaNacimiento   DateTime?
  sexo              String?   // Masculino / Femenino / Otro / Prefiero no indicar
  nacionalidad      String?
  estadoCivil       String?   // Soltero/a / Casado/a / Unión libre / Divorciado/a / Viudo/a

  // ── Información de contacto ───────────────────────
  telefonoPersonal  String?
  emailPersonal     String?
  direccion         String?
  ciudad            String?
  pais              String?   @default("Colombia")

  // ── Información laboral ───────────────────────────
  cargo             String?
  area              String?
  tipoContrato      String?   // Fijo / Indefinido / Prestación de servicios / Aprendizaje / Obra o labor
  fechaIngreso      DateTime?
  salario           Decimal?  @db.Decimal(12, 2)
  jornadaLaboral    String?   // Completa / Medio tiempo / Por horas / Flexible
  jefeDirecto       String?
  telefonoCorporativo String?

  // ── Formación académica ───────────────────────────
  nivelEducativo    String?
  titulo            String?
  institucion       String?
  anoGraduacion     Int?

  // ── Experiencia laboral ───────────────────────────
  empresaAnterior      String?
  cargoAnterior        String?
  tiempoTrabajado      String?
  funcionesAnteriores  String?

  // ── Habilidades y competencias ────────────────────
  habilidadesTecnicas String[]
  habilidadesBlandas  String[]
  idiomas             Json?    // [{idioma: string, nivel: string}]

  // ── Seguridad social ──────────────────────────────
  eps               String?
  fondoPension      String?
  arl               String?
  cajaCompensacion  String?

  // ── Información financiera ────────────────────────
  banco             String?
  tipoCuenta        String?   // Ahorros / Corriente
  numeroCuenta      String?

  // ── Contacto de emergencia ────────────────────────
  emergenciaNombre   String?
  emergenciaRelacion String?
  emergenciaTelefono String?

  // ── Documentación legal (rutas/URLs) ─────────────
  cedulaArchivo     String?
  hojaVidaArchivo   String?

  // ── Sesión / Refresh tokens ───────────────────────
  refreshTokenHash    String?   @db.VarChar(128)  // SHA-256 del refresh token
  refreshTokenExpiry  DateTime?

  // ── Control de acceso / Bloqueo por fuerza bruta ──
  loginFallidosConsecutivos  Int       @default(0)
  loginBloqueadoHasta        DateTime? // null = no bloqueado

  // ── Relaciones ────────────────────────────────────
  perfilCargoId Int?
  perfilCargo   PerfilCargo? @relation(fields: [perfilCargoId], references: [id])
  clientes           ClienteManager[] @relation("AsesorClientes")
  ticketsSAC         Ticket[]         @relation("TicketsSAC")
  ticketsDesarrollo  Ticket[]         @relation("TicketsDesarrollo")

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model PlanBase {
  id             Int              @id @default(autoincrement())
  nombre         String           @unique
  descripcion    String?
  precioBase     Decimal          @db.Decimal(12, 2)
  limiteUsuarios Int?
  clientes       ClienteManager[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ModuloSoftware {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique
  slug          String        @unique
  descripcion   String?
  icono         String?
  precioAnual   Decimal       @db.Decimal(12, 2)
  activo        Boolean       @default(true)
  planesCliente PlanCliente[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ClienteManager {
  id            Int           @id @default(autoincrement())

  // ── Identificación ────────────────────────────────
  tipoPersona       String?   // NATURAL, JURIDICA
  tipoDocumento     String?   // NIT, CC, CE, PASAPORTE
  nit               String    @unique  // número de identificación principal
  digitoVerificacion String?
  nombre            String    // nombre completo o razón social

  // ── Ubicación ─────────────────────────────────────
  pais              String?
  departamento      String?
  ciudad            String?
  direccion         String?
  codigoPostal      String?

  // ── Contacto ──────────────────────────────────────
  email             String?
  telefonoAlternativo String?
  telefono          String?
  paginaWeb         String?
  contacto          String?   // nombre del contacto principal

  // ── Comercial ─────────────────────────────────────
  tipoCliente       String?   // MINORISTA, MAYORISTA, VIP, DISTRIBUIDOR
  listaPrecios      String?
  cupoCredito       Decimal?  @db.Decimal(14, 2)
  condicionesPago   String?   // CONTADO, CREDITO_15, CREDITO_30, CREDITO_60
  estado            String    @default("PROSPECTO")

  // ── Tributario (DIAN) ─────────────────────────────
  regimenTributario     String?   // RESPONSABLE_IVA, NO_RESPONSABLE, SIMPLE
  responsabilidadFiscal String?   // texto libre o códigos RUT
  actividadEconomica    String?   // código CIIU
  granContribuyente     Boolean   @default(false)
  autorretenedor        Boolean   @default(false)
  agenteRetencion       Boolean   @default(false)

  // ── Financiero ────────────────────────────────────
  banco             String?
  tipoCuenta        String?   // AHORROS, CORRIENTE
  numeroCuenta      String?

  // ── Interno ───────────────────────────────────────
  segmento          String?
  observaciones     String?

  // ── Relaciones ────────────────────────────────────
  planBaseId    Int?
  planBase      PlanBase?     @relation(fields: [planBaseId], references: [id])
  asesorId      Int?
  asesor        Colaborador?  @relation("AsesorClientes", fields: [asesorId], references: [id])
  modulosActivos PlanCliente[]
  tickets        Ticket[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PlanCliente {
  id              Int            @id @default(autoincrement())
  clienteId       Int
  cliente         ClienteManager @relation(fields: [clienteId], references: [id])
  moduloId        Int
  modulo          ModuloSoftware @relation(fields: [moduloId], references: [id])
  precioNegociado Decimal?       @db.Decimal(12, 2)
  activo          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULO DE SOPORTE
// ─────────────────────────────────────────────────────────────────────────────

model Ticket {
  id       Int    @id @default(autoincrement())
  numero   String @unique // TKT-2026-00001

  // ── Origen ────────────────────────────────────────
  origen     String  // CHAT, TICKET_DIRECTO
  clienteId  Int
  cliente    ClienteManager @relation(fields: [clienteId], references: [id])

  // ── Contenido ─────────────────────────────────────
  asunto      String
  descripcion String
  prioridad   String  @default("MEDIA")  // BAJA, MEDIA, ALTA, CRITICA
  categoria   String? // BUG, MEJORA, CONSULTA, CONFIGURACION

  // ── Estado y asignación ───────────────────────────
  estado          String  @default("NUEVO") // NUEVO, SAC, DESARROLLO, DEVUELTO, RESUELTO, CALIFICADO
  asesorSacId     Int?
  asesorSac       Colaborador? @relation("TicketsSAC",         fields: [asesorSacId],     references: [id])
  desarrolladorId Int?
  desarrollador   Colaborador? @relation("TicketsDesarrollo",  fields: [desarrolladorId], references: [id])

  // ── Calificación ──────────────────────────────────
  calificacion     Int?
  calificadoAt     DateTime?
  calificacionAuto Boolean  @default(false)
  venceCalifAt     DateTime?

  // ── Fechas clave ──────────────────────────────────
  resueltoAt DateTime?

  // ── Relaciones ────────────────────────────────────
  mensajes TicketMensaje[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketMensaje {
  id       Int    @id @default(autoincrement())
  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  autor    String  // CLIENTE, SAC, DESARROLLO, IA
  autorId  Int?    // id del colaborador (null si es cliente o IA)
  nombre   String? // nombre para mostrar
  contenido String
  interno  Boolean @default(false) // nota interna, no visible al cliente

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG — Registro de eventos de seguridad y acceso a datos sensibles
// ─────────────────────────────────────────────────────────────────────────────

// ─── MÓDULO INVENTARIO ERP ────────────────────────────────────────────────────

model Categoria {
  id          Int          @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  nombre      String
  slug        String
  descripcion String?
  parentId    Int?
  parent      Categoria?   @relation("Subcategorias", fields: [parentId], references: [id])
  hijos       Categoria[]  @relation("Subcategorias")
  productos   Producto[]
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([empresaId, slug])
  @@index([empresaId])
}

model Marca {
  id        Int        @id @default(autoincrement())
  empresaId Int
  empresa   Empresa    @relation(fields: [empresaId], references: [id])
  nombre    String
  activo    Boolean    @default(true)
  productos Producto[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([empresaId, nombre])
}

model UnidadMedida {
  id          Int        @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa    @relation(fields: [empresaId], references: [id])
  nombre      String
  abreviatura String
  tipo        String     @default("UNIDAD")
  factorBase  Decimal    @default(1) @db.Decimal(12, 6)
  activo      Boolean    @default(true)
  productos   Producto[]
  createdAt   DateTime   @default(now())

  @@unique([empresaId, abreviatura])
}

model Producto {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  sku             String
  codigoBarras    String?
  nombre          String
  descripcion     String?
  referencia      String?

  categoriaId     Int?
  categoria       Categoria?    @relation(fields: [categoriaId], references: [id])
  marcaId         Int?
  marca           Marca?        @relation(fields: [marcaId], references: [id])
  unidadMedidaId  Int?
  unidadMedida    UnidadMedida? @relation(fields: [unidadMedidaId], references: [id])

  costoPromedio   Decimal  @default(0) @db.Decimal(14, 4)
  precioBase      Decimal  @default(0) @db.Decimal(14, 2)

  tipoIva         String   @default("GRAVADO_19")

  manejaBodega    Boolean  @default(true)
  manejaLotes     Boolean  @default(false)
  manejaSerial    Boolean  @default(false)
  stockMinimo     Decimal  @default(0)  @db.Decimal(12, 3)
  stockMaximo     Decimal? @db.Decimal(12, 3)
  puntoReorden    Decimal  @default(0)  @db.Decimal(12, 3)
  diasRotacion    Int?

  claseAbc        String?
  claseAbcFecha   DateTime?

  activo          Boolean  @default(true)
  imagen          String?

  stock           Stock[]
  movimientos     MovimientoInventario[]
  ordenesCompraItems OrdenCompraItem[]
  lotes           Lote[]
  seriales        NumeroSerie[]
  variantes       VarianteProducto[]
  facturaItems    FacturaVentaItem[]
  cotizacionItems CotizacionItem[]
  ventaPosItems   VentaPosItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([empresaId, sku])
  @@index([empresaId])
  @@index([empresaId, codigoBarras])
  @@index([empresaId, activo])
}

model Bodega {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  codigo      String
  nombre      String
  tipo        String   @default("ALMACEN")
  direccion   String?
  esPrincipal Boolean  @default(false)
  activo      Boolean  @default(true)

  stock                Stock[]
  movimientosOrigen    MovimientoInventario[] @relation("MovOrigen")
  movimientosDestino   MovimientoInventario[] @relation("MovDestino")
  ordenesCompra        OrdenCompra[]
  lotes                Lote[]
  seriales             NumeroSerie[]
  stockVariantes       StockVariante[]
  facturasVenta        FacturaVenta[]
  cajasPos             CajaPos[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([empresaId, codigo])
  @@index([empresaId])
}

model Stock {
  id                Int      @id @default(autoincrement())
  empresaId         Int
  empresa           Empresa  @relation(fields: [empresaId], references: [id])
  productoId        Int
  producto          Producto @relation(fields: [productoId], references: [id])
  bodegaId          Int
  bodega            Bodega   @relation(fields: [bodegaId], references: [id])

  cantidad          Decimal  @default(0) @db.Decimal(12, 3)
  cantidadReservada Decimal  @default(0) @db.Decimal(12, 3)

  updatedAt         DateTime @updatedAt

  @@unique([productoId, bodegaId])
  @@index([empresaId])
  @@index([empresaId, productoId])
}

model MovimientoInventario {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  numero      String   @unique

  tipo        String
  concepto    String

  productoId       Int
  producto         Producto @relation(fields: [productoId], references: [id])
  bodegaOrigenId   Int?
  bodegaOrigen     Bodega?  @relation("MovOrigen",  fields: [bodegaOrigenId],  references: [id])
  bodegaDestinoId  Int?
  bodegaDestino    Bodega?  @relation("MovDestino", fields: [bodegaDestinoId], references: [id])

  cantidad         Decimal  @db.Decimal(12, 3)
  costoUnitario    Decimal  @default(0) @db.Decimal(14, 4)
  costoTotal       Decimal  @default(0) @db.Decimal(14, 2)

  saldoCantidad    Decimal  @db.Decimal(12, 3)
  saldoCostoTotal  Decimal  @db.Decimal(14, 2)
  saldoCpp         Decimal  @db.Decimal(14, 4)

  usuarioId        Int?
  referenciaId     String?
  referenciaTipo   String?
  movimientoParId  Int?
  notas            String?

  fechaMovimiento  DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([empresaId, productoId])
  @@index([empresaId, productoId, fechaMovimiento])
  @@index([empresaId, tipo])
  @@index([empresaId, fechaMovimiento])
  @@index([referenciaId, referenciaTipo])
}

model Proveedor {
  id              Int           @id @default(autoincrement())
  empresaId       Int
  empresa         Empresa       @relation(fields: [empresaId], references: [id])

  tipoDocumento   String?
  numeroDocumento String?
  nombre          String
  nombreComercial String?

  email           String?
  telefono        String?
  contactoNombre  String?
  direccion       String?
  ciudad          String?
  pais            String        @default("Colombia")

  plazoEntregaDias Int?
  condicionesPago  String?
  descuentoBase    Decimal?     @db.Decimal(5, 2)
  moneda           String       @default("COP")

  activo          Boolean       @default(true)
  notas           String?
  ordenesCompra   OrdenCompra[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([empresaId])
}

model OrdenCompra {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  numero      String   @unique
  proveedorId Int
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id])
  bodegaId    Int
  bodega      Bodega   @relation(fields: [bodegaId], references: [id])

  estado      String   @default("BORRADOR")

  fechaEmision    DateTime  @default(now())
  fechaEsperada   DateTime?
  fechaRecepcion  DateTime?

  subtotal    Decimal  @default(0) @db.Decimal(14, 2)
  descuento   Decimal  @default(0) @db.Decimal(14, 2)
  iva         Decimal  @default(0) @db.Decimal(14, 2)
  total       Decimal  @default(0) @db.Decimal(14, 2)

  usuarioId   Int?
  notas       String?

  items       OrdenCompraItem[]
  recepciones RecepcionMercancia[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([empresaId, estado])
  @@index([empresaId, proveedorId])
}

model OrdenCompraItem {
  id            Int         @id @default(autoincrement())
  ordenCompraId Int
  ordenCompra   OrdenCompra @relation(fields: [ordenCompraId], references: [id])
  productoId    Int
  producto      Producto    @relation(fields: [productoId], references: [id])

  cantidad          Decimal  @db.Decimal(12, 3)
  cantidadRecibida  Decimal  @default(0) @db.Decimal(12, 3)
  costoUnitario     Decimal  @db.Decimal(14, 4)
  descuentoPct      Decimal  @default(0) @db.Decimal(5, 2)
  subtotal          Decimal  @db.Decimal(14, 2)
  ivaValor          Decimal  @default(0) @db.Decimal(14, 2)
  total             Decimal  @db.Decimal(14, 2)

  recepcionItems    RecepcionItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RecepcionMercancia {
  id            Int         @id @default(autoincrement())
  empresaId     Int
  empresa       Empresa     @relation(fields: [empresaId], references: [id])
  ordenCompraId Int
  ordenCompra   OrdenCompra @relation(fields: [ordenCompraId], references: [id])

  numero        String      @unique
  fecha         DateTime    @default(now())
  usuarioId     Int?
  notas         String?

  items         RecepcionItem[]

  createdAt     DateTime    @default(now())
}

model RecepcionItem {
  id                  Int                 @id @default(autoincrement())
  recepcionId         Int
  recepcion           RecepcionMercancia  @relation(fields: [recepcionId], references: [id])
  ordenCompraItemId   Int
  ordenCompraItem     OrdenCompraItem     @relation(fields: [ordenCompraItemId], references: [id])

  cantidadRecibida    Decimal  @db.Decimal(12, 3)
  costoUnitario       Decimal  @db.Decimal(14, 4)

  createdAt           DateTime @default(now())
}

// ─── SPRINT 4: Lotes, Seriales, Variantes ────────────────────────────────────

model Lote {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  productoId       Int
  producto         Producto @relation(fields: [productoId], references: [id])
  bodegaId         Int
  bodega           Bodega   @relation(fields: [bodegaId], references: [id])

  numero           String
  fechaVencimiento DateTime?
  fechaFabricacion DateTime?
  proveedor        String?
  cantidadInicial  Decimal  @default(0) @db.Decimal(12, 3)
  cantidad         Decimal  @default(0) @db.Decimal(12, 3)
  activo           Boolean  @default(true)
  notas            String?

  seriales         NumeroSerie[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([empresaId, productoId, bodegaId, numero])
  @@index([empresaId, productoId])
  @@index([empresaId, fechaVencimiento])
}

model NumeroSerie {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  productoId  Int
  producto    Producto @relation(fields: [productoId], references: [id])
  bodegaId    Int?
  bodega      Bodega?  @relation(fields: [bodegaId], references: [id])
  loteId      Int?
  lote        Lote?    @relation(fields: [loteId], references: [id])

  serial      String
  estado      String   @default("DISPONIBLE") // DISPONIBLE | VENDIDO | DEVUELTO | BAJA
  notas       String?

  movimientoEntradaId Int?
  movimientoSalidaId  Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([empresaId, productoId, serial])
  @@index([empresaId, productoId])
  @@index([empresaId, estado])
}

model VarianteProducto {
  id             Int      @id @default(autoincrement())
  empresaId      Int
  empresa        Empresa  @relation(fields: [empresaId], references: [id])
  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id])

  sku            String
  nombre         String
  atributos      Json     // [{ nombre: "Talla", valor: "L" }, { nombre: "Color", valor: "Rojo" }]
  costoPromedio  Decimal  @default(0) @db.Decimal(14, 4)
  precioBase     Decimal  @default(0) @db.Decimal(14, 2)
  codigoBarras   String?
  imagen         String?
  activo         Boolean  @default(true)

  stock          StockVariante[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([empresaId, sku])
  @@index([empresaId, productoId])
}

model StockVariante {
  id                Int              @id @default(autoincrement())
  empresaId         Int
  varianteId        Int
  variante          VarianteProducto @relation(fields: [varianteId], references: [id])
  bodegaId          Int
  bodega            Bodega           @relation(fields: [bodegaId], references: [id])

  cantidad          Decimal  @default(0) @db.Decimal(12, 3)
  cantidadReservada Decimal  @default(0) @db.Decimal(12, 3)

  updatedAt         DateTime @updatedAt

  @@unique([varianteId, bodegaId])
  @@index([empresaId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// MÓDULO VENTAS
// ═══════════════════════════════════════════════════════════════════════════════

model ClienteERP {
  id                  Int      @id @default(autoincrement())
  empresaId           Int
  empresa             Empresa  @relation(fields: [empresaId], references: [id])

  // Identificación
  tipoPersona         String   @default("JURIDICA")    // NATURAL | JURIDICA
  tipoDocumento       String   @default("NIT")         // NIT | CC | CE | PASAPORTE | PEP
  numeroDocumento     String
  digitoVerificacion  String?
  nombre              String
  nombreComercial     String?

  // Tributario DIAN
  regimenFiscal       String   @default("49")   // 48=Responsable IVA, 49=No responsable
  responsabilidades   String[]                  // O-13, O-15, O-23, O-47
  actividadEconomica  String?                   // CIIU

  // Contacto
  email               String?
  telefono            String?
  celular             String?

  // Dirección (para UBL 2.1)
  pais                String   @default("CO")
  departamento        String?
  municipio           String?
  codigoDane          String?
  codigoPostal        String?
  direccion           String?

  // Comercial
  plazoCredito        Int      @default(0)
  cupoCredito         Decimal? @db.Decimal(15,2)
  descuentoBase       Decimal  @default(0) @db.Decimal(5,2)
  vendedorId          Int?

  activo              Boolean  @default(true)
  notas               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cotizaciones        Cotizacion[]
  facturas            FacturaVenta[]
  notasCredito        NotaCredito[]
  recibos             ReciboCaja[]
  ventasPos           VentaPos[]

  @@unique([empresaId, tipoDocumento, numeroDocumento])
  @@index([empresaId])
  @@index([empresaId, activo])
}

model ConfiguracionDIAN {
  id                Int      @id @default(autoincrement())
  empresaId         Int      @unique
  empresa           Empresa  @relation(fields: [empresaId], references: [id])

  ambiente          String   @default("PRUEBAS")  // PRUEBAS | PRODUCCION
  softwareId        String?
  softwarePin       String?
  certificadoPath   String?
  certificadoPass   String?

  // Proveedor tecnológico (alternativa al envío directo)
  proveedorTec      String?   // CARVAJAL | GOSOCKET | EDICOM | DIRECTO
  proveedorApiKey   String?
  proveedorUrl      String?

  activo            Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  resoluciones      ResolucionDIAN[]
}

model ResolucionDIAN {
  id                Int               @id @default(autoincrement())
  configId          Int
  config            ConfiguracionDIAN @relation(fields: [configId], references: [id])

  tipoDocumento     String   @default("01")  // 01=FV, 91=NC, 92=ND
  prefijo           String   @default("")
  numeroCurrent     Int      @default(0)
  numeroInicial     Int
  numeroFinal       Int
  fechaResolucion   DateTime
  fechaVigencia     DateTime
  numeroResolucion  String
  claveTecnica      String   // para calcular CUFE

  activo            Boolean  @default(true)

  facturas          FacturaVenta[]
  notasCredito      NotaCredito[]
}

model Cotizacion {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  numero           String

  clienteId        Int
  cliente          ClienteERP @relation(fields: [clienteId], references: [id])
  bodegaId         Int

  fecha            DateTime @default(now())
  fechaVencimiento DateTime

  estado           String   @default("BORRADOR")
  // BORRADOR | ENVIADA | ACEPTADA | RECHAZADA | VENCIDA | FACTURADA

  // Totales
  subtotal         Decimal  @default(0) @db.Decimal(15,2)
  descuento        Decimal  @default(0) @db.Decimal(15,2)
  baseIva19        Decimal  @default(0) @db.Decimal(15,2)
  iva19            Decimal  @default(0) @db.Decimal(15,2)
  baseIva5         Decimal  @default(0) @db.Decimal(15,2)
  iva5             Decimal  @default(0) @db.Decimal(15,2)
  total            Decimal  @default(0) @db.Decimal(15,2)

  notas            String?
  condicionesPago  String?
  usuarioId        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            CotizacionItem[]
  facturas         FacturaVenta[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
}

model CotizacionItem {
  id               Int        @id @default(autoincrement())
  cotizacionId     Int
  cotizacion       Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId       Int
  producto         Producto   @relation(fields: [productoId], references: [id])

  descripcion      String
  unidad           String     @default("UND")
  cantidad         Decimal    @db.Decimal(15,4)
  precioUnitario   Decimal    @db.Decimal(15,2)
  descuentoPct     Decimal    @default(0) @db.Decimal(5,2)
  descuentoValor   Decimal    @default(0) @db.Decimal(15,2)
  tipoIva          String     @default("IVA_19")
  // IVA_19 | IVA_5 | IVA_0 | EXCLUIDO
  baseIva          Decimal    @default(0) @db.Decimal(15,2)
  ivaValor         Decimal    @default(0) @db.Decimal(15,2)
  subtotal         Decimal    @db.Decimal(15,2)
  total            Decimal    @db.Decimal(15,2)
  orden            Int        @default(0)
}

model FacturaVenta {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa  @relation(fields: [empresaId], references: [id])

  numero           String   // prefijoDIAN + numeroDIAN
  clienteId        Int
  cliente          ClienteERP @relation(fields: [clienteId], references: [id])
  bodegaId         Int
  bodega           Bodega   @relation(fields: [bodegaId], references: [id])

  cotizacionId     Int?
  cotizacion       Cotizacion? @relation(fields: [cotizacionId], references: [id])

  // DIAN
  resolucionId     Int?
  resolucion       ResolucionDIAN? @relation(fields: [resolucionId], references: [id])
  prefijoDIAN      String?
  numeroDIAN       Int?
  cufe             String?   @db.Text
  qrUrl            String?
  xmlDIAN          String?   @db.Text
  respuestaDIAN    Json?
  estadoDIAN       String    @default("PENDIENTE")
  // PENDIENTE | ENVIADA | ACEPTADA | RECHAZADA | ERROR

  fecha            DateTime  @default(now())
  fechaVencimiento DateTime?

  formaPago        String    @default("CREDITO")  // CONTADO | CREDITO
  medioPago        String    @default("TRANSFERENCIA")
  // EFECTIVO | TRANSFERENCIA | CHEQUE | TARJETA_CREDITO | TARJETA_DEBITO

  estado           String    @default("BORRADOR")
  // BORRADOR | EMITIDA | PAGADA | PARCIAL | ANULADA

  // Retenciones (aplicadas por el cliente agente retenedor)
  retefuente       Decimal   @default(0) @db.Decimal(15,2)
  reteiva          Decimal   @default(0) @db.Decimal(15,2)
  reteica          Decimal   @default(0) @db.Decimal(15,2)

  // Totales
  subtotal         Decimal   @default(0) @db.Decimal(15,2)
  descuento        Decimal   @default(0) @db.Decimal(15,2)
  baseIva19        Decimal   @default(0) @db.Decimal(15,2)
  iva19            Decimal   @default(0) @db.Decimal(15,2)
  baseIva5         Decimal   @default(0) @db.Decimal(15,2)
  iva5             Decimal   @default(0) @db.Decimal(15,2)
  total            Decimal   @default(0) @db.Decimal(15,2)
  totalPagado      Decimal   @default(0) @db.Decimal(15,2)
  saldo            Decimal   @default(0) @db.Decimal(15,2)

  notas            String?
  usuarioId        Int?
  comprobanteId    Int?      // asiento contable generado
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  items            FacturaVentaItem[]
  notasCredito     NotaCredito[]
  recibos          ReciboCajaFactura[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@index([empresaId, clienteId])
  @@index([empresaId, fecha])
  @@index([empresaId, estadoDIAN])
}

model FacturaVentaItem {
  id               Int          @id @default(autoincrement())
  facturaId        Int
  factura          FacturaVenta @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  productoId       Int
  producto         Producto     @relation(fields: [productoId], references: [id])

  descripcion      String
  unidad           String       @default("UND")
  cantidad         Decimal      @db.Decimal(15,4)
  precioUnitario   Decimal      @db.Decimal(15,2)
  descuentoPct     Decimal      @default(0) @db.Decimal(5,2)
  descuentoValor   Decimal      @default(0) @db.Decimal(15,2)
  tipoIva          String       @default("IVA_19")
  baseIva          Decimal      @default(0) @db.Decimal(15,2)
  ivaValor         Decimal      @default(0) @db.Decimal(15,2)
  subtotal         Decimal      @db.Decimal(15,2)
  total            Decimal      @db.Decimal(15,2)

  // Costo (snapshot al momento de facturar)
  costoUnitario    Decimal      @default(0) @db.Decimal(15,4)
  costoTotal       Decimal      @default(0) @db.Decimal(15,2)

  orden            Int          @default(0)
}

model NotaCredito {
  id               Int          @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa      @relation(fields: [empresaId], references: [id])
  numero           String

  facturaId        Int
  factura          FacturaVenta @relation(fields: [facturaId], references: [id])
  clienteId        Int
  cliente          ClienteERP   @relation(fields: [clienteId], references: [id])
  resolucionId     Int?
  resolucion       ResolucionDIAN? @relation(fields: [resolucionId], references: [id])

  // DIAN
  cufde            String?      @db.Text  // CUDE para NC
  xmlDIAN          String?      @db.Text
  estadoDIAN       String       @default("PENDIENTE")

  fecha            DateTime     @default(now())
  motivo           String       // DEVOLUCION | DESCUENTO | ANULACION | OTRO
  descripcion      String

  subtotal         Decimal      @default(0) @db.Decimal(15,2)
  iva              Decimal      @default(0) @db.Decimal(15,2)
  total            Decimal      @default(0) @db.Decimal(15,2)

  estado           String       @default("BORRADOR")

  items            NotaCreditoItem[]
  usuarioId        Int?
  createdAt        DateTime     @default(now())

  @@unique([empresaId, numero])
  @@index([empresaId])
}

model NotaCreditoItem {
  id               Int         @id @default(autoincrement())
  notaCreditoId    Int
  notaCredito      NotaCredito @relation(fields: [notaCreditoId], references: [id], onDelete: Cascade)
  productoId       Int?

  descripcion      String
  cantidad         Decimal     @db.Decimal(15,4)
  precioUnitario   Decimal     @db.Decimal(15,2)
  tipoIva          String      @default("IVA_19")
  ivaValor         Decimal     @default(0) @db.Decimal(15,2)
  subtotal         Decimal     @db.Decimal(15,2)
  total            Decimal     @db.Decimal(15,2)
}

model ReciboCaja {
  id               Int        @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa    @relation(fields: [empresaId], references: [id])
  numero           String
  clienteId        Int
  cliente          ClienteERP @relation(fields: [clienteId], references: [id])

  fecha            DateTime   @default(now())
  concepto         String
  valor            Decimal    @db.Decimal(15,2)
  medioPago        String
  referencia       String?
  estado           String     @default("ACTIVO")  // ACTIVO | ANULADO
  usuarioId        Int?
  createdAt        DateTime   @default(now())

  aplicaciones     ReciboCajaFactura[]

  @@unique([empresaId, numero])
  @@index([empresaId])
}

model ReciboCajaFactura {
  id               Int          @id @default(autoincrement())
  reciboId         Int
  recibo           ReciboCaja   @relation(fields: [reciboId], references: [id])
  facturaId        Int
  factura          FacturaVenta @relation(fields: [facturaId], references: [id])
  valor            Decimal      @db.Decimal(15,2)
}

// ═══════════════════════════════════════════════════════════════════════════════
// MÓDULO CONTABILIDAD (PUC colombiano — Decreto 2650)
// ═══════════════════════════════════════════════════════════════════════════════

model CuentaPUC {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa  @relation(fields: [empresaId], references: [id])

  codigo           String   // ej: "1105", "41350501"
  nombre           String
  // Nivel: 1=Clase(1 dígito), 2=Grupo(2), 3=Cuenta(4), 4=Subcuenta(6), 5=Auxiliar(8)
  nivel            Int
  codigoPadre      String?
  naturaleza       String   @default("DEBITO")   // DEBITO | CREDITO
  // Tipo macro para clasificación de estados financieros
  tipo             String
  // ACTIVO | PASIVO | PATRIMONIO | INGRESO | GASTO | COSTO

  ajustable        Boolean  @default(false)
  requiereNit      Boolean  @default(false)
  requiereCentro   Boolean  @default(false)
  activo           Boolean  @default(true)

  lineas           ComprobanteLinea[]
  cajasPos         CajaPos[]

  @@unique([empresaId, codigo])
  @@index([empresaId, nivel])
  @@index([empresaId, codigoPadre])
}

model PeriodoContable {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  anio             Int
  mes              Int      // 1-12
  estado           String   @default("ABIERTO")  // ABIERTO | CERRADO | BLOQUEADO
  fechaCierre      DateTime?

  comprobantes     Comprobante[]

  @@unique([empresaId, anio, mes])
}

model Comprobante {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa  @relation(fields: [empresaId], references: [id])

  numero           String
  tipo             String
  // FV=FacturaVenta | FP=FacturaProveedor | RC=ReciboCaja | CP=ComprobantePago
  // AJ=Ajuste | NC=NotaContabilidad | NI=NotaInterna

  concepto         String
  fecha            DateTime
  periodoId        Int
  periodo          PeriodoContable @relation(fields: [periodoId], references: [id])
  estado           String   @default("APROBADO")  // BORRADOR | APROBADO | ANULADO

  // Referencia al documento origen
  referenciaId     Int?
  referenciaTipo   String?  // FACTURA_VENTA | NOTA_CREDITO | RECIBO_CAJA | etc.

  usuarioId        Int?

  lineas           ComprobanteLinea[]

  @@unique([empresaId, numero])
  @@index([empresaId, tipo])
  @@index([empresaId, fecha])
}

model ComprobanteLinea {
  id               Int         @id @default(autoincrement())
  comprobanteId    Int
  comprobante      Comprobante @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  cuentaId         Int
  cuenta           CuentaPUC   @relation(fields: [cuentaId], references: [id])

  descripcion      String
  debito           Decimal     @default(0) @db.Decimal(15,2)
  credito          Decimal     @default(0) @db.Decimal(15,2)
  terceroNit       String?
  terceroNombre    String?
  centroCosto      String?
  orden            Int         @default(0)
}

// ═══════════════════════════════════════════════════════════════════════════════
// MÓDULO POS — Punto de Venta
// ═══════════════════════════════════════════════════════════════════════════════

model CajaPos {
  id               Int       @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa   @relation(fields: [empresaId], references: [id])

  nombre           String    // "Caja 1", "Caja Principal"
  bodegaId         Int
  bodega           Bodega    @relation(fields: [bodegaId], references: [id])
  cuentaPUCId      Int?      // Cuenta PUC efectivo (ej: 110505)
  cuentaPUC        CuentaPUC? @relation(fields: [cuentaPUCId], references: [id])

  // Vendedor por defecto
  vendedorId       Int?
  vendedorNombre   String?

  // Impresora
  impresora        String?   // IP:puerto o nombre de dispositivo
  tipoConexion     String?   @default("NETWORK") // NETWORK | USB | SERIAL | NINGUNA
  anchoPapel       Int       @default(80)  // 58 | 80 mm

  // Reglas de venta
  permiteCreditoPos Boolean  @default(false)
  permiteDescuento  Boolean  @default(true)
  maxDescuento      Decimal  @default(100) @db.Decimal(5,2)

  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sesiones         SesionCaja[]

  @@unique([empresaId, nombre])
  @@index([empresaId])
}

model SesionCaja {
  id               Int       @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa   @relation(fields: [empresaId], references: [id])
  cajaId           Int
  caja             CajaPos   @relation(fields: [cajaId], references: [id])

  vendedorId       Int?
  vendedorNombre   String?

  estado           String    @default("ABIERTA")  // ABIERTA | CERRADA

  montoInicial     Decimal   @db.Decimal(15,2)

  // Totales acumulados del turno
  totalVentas      Decimal   @default(0) @db.Decimal(15,2)
  numTransacciones Int       @default(0)
  totalEfectivo    Decimal   @default(0) @db.Decimal(15,2)
  totalTarjeta     Decimal   @default(0) @db.Decimal(15,2)
  totalTransferencia Decimal @default(0) @db.Decimal(15,2)
  totalNequi       Decimal   @default(0) @db.Decimal(15,2)
  totalAnuladas    Decimal   @default(0) @db.Decimal(15,2)

  // Cierre
  montoFinalDeclarado Decimal? @db.Decimal(15,2)
  diferencia       Decimal?  @db.Decimal(15,2)
  observacionesCierre String?

  abiertaAt        DateTime  @default(now())
  cerradaAt        DateTime?

  ventas           VentaPos[]
  movimientos      MovimientoCaja[]
  arqueo           ArqueoCaja?

  @@index([empresaId, estado])
  @@index([empresaId, cajaId])
}

model VentaPos {
  id               Int        @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa    @relation(fields: [empresaId], references: [id])
  sesionId         Int
  sesion           SesionCaja @relation(fields: [sesionId], references: [id])

  numero           String     // POS-2026-00001

  // Cliente (null = Consumidor Final)
  clienteId        Int?
  cliente          ClienteERP? @relation(fields: [clienteId], references: [id])
  clienteNombre    String      @default("Consumidor Final")
  clienteDoc       String?

  vendedorId       Int?
  vendedorNombre   String?

  fecha            DateTime    @default(now())

  // Totales
  subtotal         Decimal     @db.Decimal(15,2)
  descuento        Decimal     @default(0) @db.Decimal(15,2)
  baseIva19        Decimal     @default(0) @db.Decimal(15,2)
  iva19            Decimal     @default(0) @db.Decimal(15,2)
  baseIva5         Decimal     @default(0) @db.Decimal(15,2)
  iva5             Decimal     @default(0) @db.Decimal(15,2)
  total            Decimal     @db.Decimal(15,2)

  // Pago (puede ser mixto)
  pagoEfectivo     Decimal     @default(0) @db.Decimal(15,2)
  pagoTarjetaDebito Decimal   @default(0) @db.Decimal(15,2)
  pagoTarjetaCredito Decimal  @default(0) @db.Decimal(15,2)
  pagoTransferencia Decimal   @default(0) @db.Decimal(15,2)
  pagoNequi        Decimal     @default(0) @db.Decimal(15,2)
  cambio           Decimal     @default(0) @db.Decimal(15,2)

  estado           String      @default("COMPLETADA") // COMPLETADA | ANULADA
  motivoAnulacion  String?

  // Referencia a FacturaVenta si el cliente pidió factura electrónica
  facturaId        Int?

  // Referencia comprobante contable
  comprobanteId    Int?

  items            VentaPosItem[]

  @@unique([empresaId, numero])
  @@index([empresaId, sesionId])
  @@index([empresaId, fecha])
  @@index([empresaId, estado])
}

model VentaPosItem {
  id               Int       @id @default(autoincrement())
  ventaId          Int
  venta            VentaPos  @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId       Int
  producto         Producto  @relation(fields: [productoId], references: [id])

  descripcion      String
  sku              String?
  cantidad         Decimal   @db.Decimal(12,3)
  precioUnitario   Decimal   @db.Decimal(15,2)
  descuentoPct     Decimal   @default(0) @db.Decimal(5,2)
  descuentoValor   Decimal   @default(0) @db.Decimal(15,2)
  tipoIva          String    @default("IVA_19")
  baseIva          Decimal   @default(0) @db.Decimal(15,2)
  ivaValor         Decimal   @default(0) @db.Decimal(15,2)
  subtotal         Decimal   @db.Decimal(15,2)
  total            Decimal   @db.Decimal(15,2)
  costoUnitario    Decimal   @default(0) @db.Decimal(15,4)
  costoTotal       Decimal   @default(0) @db.Decimal(15,2)

  orden            Int       @default(0)
}

model MovimientoCaja {
  id               Int        @id @default(autoincrement())
  sesionId         Int
  sesion           SesionCaja @relation(fields: [sesionId], references: [id])

  tipo             String     // APERTURA | VENTA | ANULACION | INGRESO | RETIRO | CIERRE
  concepto         String
  monto            Decimal    @db.Decimal(15,2)
  referencia       String?    // número de venta POS

  createdAt        DateTime   @default(now())

  @@index([sesionId])
}

model ArqueoCaja {
  id               Int        @id @default(autoincrement())
  sesionId         Int        @unique
  sesion           SesionCaja @relation(fields: [sesionId], references: [id])

  // Billetes colombianos
  b100000          Int        @default(0)
  b50000           Int        @default(0)
  b20000           Int        @default(0)
  b10000           Int        @default(0)
  b5000            Int        @default(0)
  b2000            Int        @default(0)
  b1000            Int        @default(0)

  // Monedas
  m1000            Int        @default(0)
  m500             Int        @default(0)
  m200             Int        @default(0)
  m100             Int        @default(0)
  m50              Int        @default(0)

  totalContado     Decimal    @db.Decimal(15,2)
  totalSistema     Decimal    @db.Decimal(15,2)
  diferencia       Decimal    @db.Decimal(15,2)  // + sobrante, - faltante

  observaciones    String?
  createdAt        DateTime   @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id               Int       @id @default(autoincrement())

  // Tipo de evento
  accion           String    // LOGIN_OK | LOGIN_FAIL | LOGOUT | TOKEN_REFRESH | ACCESS_PII | COLABORADOR_CREATE | COLABORADOR_UPDATE | etc.

  // Entidad afectada (opcional — para acciones sobre recursos)
  entidad          String?   // Colaborador | ClienteManager | Ticket | etc.
  entidadId        Int?

  // Quién ejecutó la acción
  colaboradorId    Int?      // null en intentos de login fallidos con email desconocido
  colaboradorEmail String?   // guardamos el email aunque el colaborador sea eliminado después

  // Contexto de red
  ip               String?
  userAgent        String?

  // Información adicional libre
  detalles         Json?

  createdAt        DateTime  @default(now())

  @@index([accion])
  @@index([colaboradorId])
  @@index([colaboradorEmail])
  @@index([createdAt])
}
