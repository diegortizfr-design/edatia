// backend/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nombre    String?
  usuario   String   @unique
  password  String
  rol       String   @default("user") // admin, user, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  empresaId Int?
  empresa   Empresa? @relation(fields: [empresaId], references: [id])
}

model Profile {
  id     Int     @id @default(autoincrement())
  bio    String?
  userId Int     @unique
  user   User    @relation(fields: [userId], references: [id])
}

model Empresa {
  id        Int      @id @default(autoincrement())
  nit       String   @unique
  nombre    String
  direccion String?
  telefono  String?
  usuarios  User[]
  createdAt DateTime @default(now())
}

// ─── Edatia Manager ───────────────────────────────────────────────────────────

model PerfilCargo {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique
  descripcion   String?
  permisos      String[]
  colaboradores Colaborador[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Colaborador {
  id            Int          @id @default(autoincrement())
  email         String       @unique
  nombre        String
  password      String
  rol           String       // ADMIN | COMERCIAL | COORDINACION | OPERACION
  activo        Boolean      @default(true)
  perfilCargoId Int?
  perfilCargo   PerfilCargo? @relation(fields: [perfilCargoId], references: [id])
  clientes      ClienteManager[] @relation("AsesorClientes")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model PlanBase {
  id             Int              @id @default(autoincrement())
  nombre         String           @unique
  descripcion    String?
  precioBase     Decimal          @db.Decimal(12, 2)
  limiteUsuarios Int?
  clientes       ClienteManager[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ModuloSoftware {
  id           Int           @id @default(autoincrement())
  nombre       String        @unique
  slug         String        @unique
  descripcion  String?
  icono        String?
  precioAnual  Decimal       @db.Decimal(12, 2)
  activo       Boolean       @default(true)
  planesCliente PlanCliente[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ClienteManager {
  id            Int           @id @default(autoincrement())
  nit           String        @unique
  nombre        String
  email         String?
  telefono      String?
  direccion     String?
  ciudad        String?
  contacto      String?
  estado        String        @default("PROSPECTO") // PROSPECTO | ACTIVO | SUSPENDIDO | CANCELADO
  observaciones String?
  planBaseId    Int?
  planBase      PlanBase?     @relation(fields: [planBaseId], references: [id])
  asesorId      Int?
  asesor        Colaborador?  @relation("AsesorClientes", fields: [asesorId], references: [id])
  modulosActivos PlanCliente[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PlanCliente {
  id               Int            @id @default(autoincrement())
  clienteId        Int
  cliente          ClienteManager @relation(fields: [clienteId], references: [id])
  moduloId         Int
  modulo           ModuloSoftware @relation(fields: [moduloId], references: [id])
  precioNegociado  Decimal?       @db.Decimal(12, 2)
  activo           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}
