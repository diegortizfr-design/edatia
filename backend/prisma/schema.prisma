// backend/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nombre    String?
  usuario   String   @unique
  password  String
  rol       String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  empresaId Int?
  empresa   Empresa? @relation(fields: [empresaId], references: [id])
}

model Profile {
  id     Int     @id @default(autoincrement())
  bio    String?
  userId Int     @unique
  user   User    @relation(fields: [userId], references: [id])
}

model Empresa {
  id        Int      @id @default(autoincrement())
  nit       String   @unique
  nombre    String
  direccion String?
  telefono  String?
  usuarios  User[]
  createdAt DateTime @default(now())
}

// ─── Edatia Manager ───────────────────────────────────────────────────────────

model PerfilCargo {
  id                Int           @id @default(autoincrement())
  nombre            String        @unique
  descripcion       String?
  responsabilidades String?       // Texto libre con responsabilidades del cargo
  correoPrincipal   String?       // ej. comercial@edatia.com
  subcorreos        String[]      // ej. [comercial1@edatia.com, comercial2@edatia.com]
  permisos          String[]
  documentoUrl      String?       // URL o path al manual de funciones / PDF del área
  colaboradores     Colaborador[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Colaborador {
  id            Int          @id @default(autoincrement())

  // ── Acceso al sistema ──────────────────────────────
  email         String       @unique  // correo corporativo = login
  password      String
  rol           String       // ADMIN | COMERCIAL | COORDINACION | OPERACION
  activo        Boolean      @default(true)

  // ── Datos personales ───────────────────────────────
  nombre            String
  tipoDocumento     String?   // CC / CE / Pasaporte / NIT
  numeroDocumento   String?
  fechaNacimiento   DateTime?
  sexo              String?   // Masculino / Femenino / Otro / Prefiero no indicar
  nacionalidad      String?
  estadoCivil       String?   // Soltero/a / Casado/a / Unión libre / Divorciado/a / Viudo/a

  // ── Información de contacto ───────────────────────
  telefonoPersonal  String?
  emailPersonal     String?
  direccion         String?
  ciudad            String?
  pais              String?   @default("Colombia")

  // ── Información laboral ───────────────────────────
  cargo             String?
  area              String?
  tipoContrato      String?   // Fijo / Indefinido / Prestación de servicios / Aprendizaje / Obra o labor
  fechaIngreso      DateTime?
  salario           Decimal?  @db.Decimal(12, 2)
  jornadaLaboral    String?   // Completa / Medio tiempo / Por horas / Flexible
  jefeDirecto       String?
  telefonoCorporativo String?

  // ── Formación académica ───────────────────────────
  nivelEducativo    String?
  titulo            String?
  institucion       String?
  anoGraduacion     Int?

  // ── Experiencia laboral ───────────────────────────
  empresaAnterior      String?
  cargoAnterior        String?
  tiempoTrabajado      String?
  funcionesAnteriores  String?

  // ── Habilidades y competencias ────────────────────
  habilidadesTecnicas String[]
  habilidadesBlandas  String[]
  idiomas             Json?    // [{idioma: string, nivel: string}]

  // ── Seguridad social ──────────────────────────────
  eps               String?
  fondoPension      String?
  arl               String?
  cajaCompensacion  String?

  // ── Información financiera ────────────────────────
  banco             String?
  tipoCuenta        String?   // Ahorros / Corriente
  numeroCuenta      String?

  // ── Contacto de emergencia ────────────────────────
  emergenciaNombre   String?
  emergenciaRelacion String?
  emergenciaTelefono String?

  // ── Documentación legal (rutas/URLs) ─────────────
  cedulaArchivo     String?
  hojaVidaArchivo   String?

  // ── Relaciones ────────────────────────────────────
  perfilCargoId Int?
  perfilCargo   PerfilCargo? @relation(fields: [perfilCargoId], references: [id])
  clientes      ClienteManager[] @relation("AsesorClientes")

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model PlanBase {
  id             Int              @id @default(autoincrement())
  nombre         String           @unique
  descripcion    String?
  precioBase     Decimal          @db.Decimal(12, 2)
  limiteUsuarios Int?
  clientes       ClienteManager[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ModuloSoftware {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique
  slug          String        @unique
  descripcion   String?
  icono         String?
  precioAnual   Decimal       @db.Decimal(12, 2)
  activo        Boolean       @default(true)
  planesCliente PlanCliente[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ClienteManager {
  id            Int           @id @default(autoincrement())
  nit           String        @unique
  nombre        String
  email         String?
  telefono      String?
  direccion     String?
  ciudad        String?
  contacto      String?
  estado        String        @default("PROSPECTO")
  observaciones String?
  planBaseId    Int?
  planBase      PlanBase?     @relation(fields: [planBaseId], references: [id])
  asesorId      Int?
  asesor        Colaborador?  @relation("AsesorClientes", fields: [asesorId], references: [id])
  modulosActivos PlanCliente[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PlanCliente {
  id              Int            @id @default(autoincrement())
  clienteId       Int
  cliente         ClienteManager @relation(fields: [clienteId], references: [id])
  moduloId        Int
  modulo          ModuloSoftware @relation(fields: [moduloId], references: [id])
  precioNegociado Decimal?       @db.Decimal(12, 2)
  activo          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}
